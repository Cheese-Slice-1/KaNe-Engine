<vbox style="padding: 5px;">
    <style>
        .button {
            font-size: 20px;
        }
    </style>
    <hbox>
        <button id="openKaNeFile" text="Open KaNe File" style="color: green;" />
    </hbox>
    <vbox>
        <label id="fileLabel" text="..." style="font-size: 20px;"/>
        <tab-view id="projectTableView" width="100%" height="100%" tabPosition="top" styleName="full-width-buttons">
            <box id="fileBox" text="Project">
                <textarea id="showFileTextArea" text="" width="100%" height="100%"/>
            </box>
            <box>
                <scrollview>
                    <textarea id="singerTextArea" text="" />
                    <image id="singerImageView" imageScale=".8"/>
                </scrollview>
            </box>
        </tab-view>
    </vbox>
</vbox>